{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bim-authority-gate.local/schemas/work-package.schema.json",
  "title": "BIM Authority Gate Controlled Work Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "package_id", "status", "decision_id", "readiness",
    "item", "authority_baseline", "approved_source_evidence", "source_hierarchy",
    "allowed_component_scope", "allowed_global_ids", "protected_non_target_scope", "expected_geometry", "interface_controls",
    "coordinate_transformation", "dimensions_and_elevations",
    "expected_product_count_changes", "expected_global_id_changes",
    "regression_requirements", "gui_requirements", "independent_review_requirements",
    "output_paths", "unresolved_assumptions", "roles", "write_policy", "external_provenance"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "package_id": {"type": "string", "pattern": "^WP-[0-9A-F]{16}$"},
    "status": {"const": "CONTROLLED_WORK_PACKAGE_READY"},
    "decision_id": {"type": "string", "pattern": "^DEC-[0-9A-F]{16}$"},
    "readiness": {"const": "READY_TO_MODEL"},
    "item": {"type": "object"},
    "authority_baseline": {"type": "object"},
    "approved_source_evidence": {"type": "array", "minItems": 1},
    "source_hierarchy": {"type": "array", "minItems": 1},
    "allowed_component_scope": {"type": "array", "minItems": 1},
    "allowed_global_ids": {"type": "array"},
    "protected_non_target_scope": {"type": "array", "minItems": 1},
    "expected_geometry": {"type": "object"},
    "interface_controls": {"type": "object"},
    "coordinate_transformation": {"type": "object"},
    "dimensions_and_elevations": {"type": "object"},
    "expected_product_count_changes": {"type": "object"},
    "expected_global_id_changes": {"type": "object"},
    "regression_requirements": {"type": "array", "minItems": 1},
    "gui_requirements": {"type": "object"},
    "independent_review_requirements": {"type": "array", "minItems": 1},
    "output_paths": {"type": "object"},
    "unresolved_assumptions": {"const": []},
    "roles": {"type": "object"},
    "external_provenance": {"type": ["object", "null"]},
    "write_policy": {
      "type": "object",
      "required": ["authority_model", "modeling_target", "self_promotion_allowed", "single_work_writer_required"],
      "properties": {
        "authority_model": {"const": "READ_ONLY"},
        "modeling_target": {"const": "ISOLATED_WORK_ONLY"},
        "self_promotion_allowed": {"const": false},
        "single_work_writer_required": {"const": true}
      }
    }
  }
}
