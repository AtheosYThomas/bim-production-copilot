{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bim-authority-gate.local/schemas/independent-review.schema.json",
  "title": "Independent read-only review result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "status", "review_result", "rev_promotion_allowed",
    "review_policy", "reviewer_role_id", "reviewer_session", "modeler_role_id",
    "package_id", "decision_id", "candidate", "authority",
    "reviewer_independence", "packet_integrity", "authority_baseline_match",
    "source_sufficiency", "readiness_decision_review", "work_package_scope_review",
    "target_geometry_review", "non_target_difference_review",
    "coordinate_and_placement_review", "support_and_continuity_review",
    "gui_evidence_review", "unauthorized_assumptions",
    "B0_count", "B1_count", "B2_count", "issue_counts", "findings", "evidence"
  ],
  "properties": {
    "schema_version": {"enum": ["1.0", "1.1"]},
    "status": {"enum": ["PASS", "FAIL"]},
    "review_result": {"enum": ["PASS", "REJECTED"]},
    "rev_promotion_allowed": {"type": "boolean"},
    "disposition": {"enum": ["PROMOTION_ELIGIBLE", "RETURN_TO_ORIGINAL_MODELING_ROLE"]},
    "review_policy": {"const": "READ_ONLY"},
    "reviewer_role_id": {"type": "string", "minLength": 1},
    "reviewer_session": {"type": "string", "minLength": 1},
    "modeler_role_id": {"type": "string", "minLength": 1},
    "package_id": {"type": "string", "pattern": "^WP-"},
    "decision_id": {"type": "string", "pattern": "^DEC-"},
    "candidate": {"$ref": "#/$defs/hash_pair"},
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rev", "sha256_before", "sha256_after", "unchanged", "product_count", "global_id_fingerprint"],
      "properties": {
        "rev": {"type": "string", "minLength": 1},
        "sha256_before": {"$ref": "#/$defs/sha256"},
        "sha256_after": {"$ref": "#/$defs/sha256"},
        "unchanged": {"type": "boolean"},
        "product_count": {"type": "integer", "minimum": 0},
        "global_id_fingerprint": {"$ref": "#/$defs/sha256"}
      }
    },
    "reviewer_independence": {"$ref": "#/$defs/review_section"},
    "packet_integrity": {"$ref": "#/$defs/review_section"},
    "authority_baseline_match": {"$ref": "#/$defs/review_section"},
    "source_sufficiency": {"$ref": "#/$defs/review_section"},
    "readiness_decision_review": {"$ref": "#/$defs/review_section"},
    "work_package_scope_review": {"$ref": "#/$defs/review_section"},
    "target_geometry_review": {"$ref": "#/$defs/review_section"},
    "non_target_difference_review": {"$ref": "#/$defs/review_section"},
    "coordinate_and_placement_review": {"$ref": "#/$defs/review_section"},
    "support_and_continuity_review": {"$ref": "#/$defs/review_section"},
    "gui_evidence_review": {"$ref": "#/$defs/review_section"},
    "unauthorized_assumptions": {"$ref": "#/$defs/review_section"},
    "B0_count": {"type": "integer", "minimum": 0},
    "B1_count": {"type": "integer", "minimum": 0},
    "B2_count": {"type": "integer", "minimum": 0},
    "issue_counts": {"$ref": "#/$defs/issue_counts"},
    "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence_record"}}
  },
  "allOf": [
    {
      "if": {"properties": {"review_result": {"const": "PASS"}}},
      "then": {
        "properties": {
          "status": {"const": "PASS"},
          "rev_promotion_allowed": {"const": true},
          "B0_count": {"const": 0},
          "B1_count": {"const": 0},
          "B2_count": {"const": 0},
          "findings": {"maxItems": 0}
        }
      }
    },
    {
      "if": {"properties": {"review_result": {"const": "REJECTED"}}},
      "then": {
        "properties": {
          "status": {"const": "FAIL"},
          "rev_promotion_allowed": {"const": false},
          "disposition": {"const": "RETURN_TO_ORIGINAL_MODELING_ROLE"}
        }
      }
    }
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9A-F]{64}$"},
    "hash_pair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sha256_before", "sha256_after"],
      "properties": {
        "sha256_before": {"$ref": "#/$defs/sha256"},
        "sha256_after": {"$ref": "#/$defs/sha256"}
      }
    },
    "review_section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "summary", "evidence_refs"],
      "properties": {
        "status": {"enum": ["PASS", "FAIL"]},
        "summary": {"type": "string", "minLength": 1},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "issue_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["B0", "B1", "B2"],
      "properties": {
        "B0": {"type": "integer", "minimum": 0},
        "B1": {"type": "integer", "minimum": 0},
        "B2": {"type": "integer", "minimum": 0}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "code", "summary", "evidence_refs"],
      "properties": {
        "severity": {"enum": ["B0", "B1", "B2"]},
        "code": {"type": "string", "minLength": 1},
        "summary": {"type": "string", "minLength": 1},
        "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
      }
    },
    "evidence_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "verification", "result"],
      "properties": {
        "ref": {"type": "string", "minLength": 1},
        "verification": {"type": "string", "minLength": 1},
        "result": {"type": "string", "minLength": 1}
      }
    }
  }
}
