{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bim-authority-gate.local/schemas/readiness-decision.schema.json",
  "title": "BIM Authority Gate Readiness Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "decision_id", "item_id", "item_name", "status",
    "modeling_allowed", "work_package_allowed", "authority_write_allowed",
    "authority_baseline_rev", "authority_baseline_sha256",
    "observed_authority_sha256", "reasons", "next_action"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "decision_id": {"type": "string", "pattern": "^DEC-[0-9A-F]{16}$"},
    "item_id": {"type": "string", "minLength": 1},
    "item_name": {"type": "string", "minLength": 1},
    "status": {
      "enum": [
        "READY_TO_MODEL", "CROSSCHECK_REQUIRED",
        "HUMAN_CLARIFICATION_REQUIRED", "COORDINATION_REQUIRED", "BLOCKED"
      ]
    },
    "modeling_allowed": {"type": "boolean"},
    "work_package_allowed": {"type": "boolean"},
    "authority_write_allowed": {"const": false},
    "authority_baseline_rev": {"type": "string"},
    "authority_baseline_sha256": {"type": "string"},
    "observed_authority_sha256": {"type": "string"},
    "reasons": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["code", "message", "evidence_ids"],
        "properties": {
          "code": {"type": "string", "minLength": 1},
          "message": {"type": "string", "minLength": 1},
          "evidence_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "next_action": {"type": "string", "minLength": 1}
  }
}

